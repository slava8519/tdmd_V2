# M8 integration-smoke TDMD config — Pattern 2 SNAP W BCC NVE, 10 steps,
# 2-rank MPI with MpiHostStaging backend, GPU runtime, 2 subdomains (Pattern 2
# K=1 P_space=2). Closes M8 T8.13 (v1.0.0-alpha1 release-gate smoke).
#
# Exec pack: docs/development/m8_execution_pack.md §T8.13.
# SPEC: docs/specs/scheduler/SPEC.md Pattern 2 integration (T7.2/T7.7);
#       docs/specs/zoning/SPEC.md (subdomains linear_1d);
#       docs/specs/comm/SPEC.md §3 (MpiHostStaging);
#       docs/specs/potentials/SPEC.md SNAP;
#       master spec §14 M8.
# Decisions: D-M8-13 (byte-exact chain extension to SNAP — D-M7-10 analog),
#            D-M8-7  (1-rank CPU FP64 byte-exact oracle gate),
#            D-M8-3  (LAMMPS submodule ships SNAP coeff files; none tracked
#                     TDMD-side).
#
# The D-M8-13 acceptance gate: with `runtime.backend: gpu`,
# `scheduler.td_mode: true`, `pipeline_depth_cap: 1`,
# `comm.backend: mpi_host_staging`, `zoning.subdomains: [2, 1, 1]`,
# a 2-rank `Fp64ReferenceBuild` run MUST produce thermo byte-identical to
# a 1-rank `Fp64ReferenceBuild` run of the same config (subdomains removed).
# This mirrors the D-M7-10 chain on EAM and extends it to SNAP.
#
# Fixture: T6 canonical 1024-atom W BCC (verify/benchmarks/t6_snap_tungsten/
# setup_1024.data, LFS). SNAP coeff/param: Wood 2017 W_2940 via LAMMPS
# submodule (D-M8-3).
#
# The harness substitutes {{ATOMS_PATH}}, {{SNAP_COEFF}}, {{SNAP_PARAM}} at
# smoke-run time.

simulation:
  units: metal
  seed: 12345               # unused at ingest (atoms read verbatim).

atoms:
  source: lammps_data
  path: "{{ATOMS_PATH}}"    # verify/benchmarks/t6_snap_tungsten/setup_1024.data (LFS)

potential:
  style: snap
  params:
    coeff_file: "{{SNAP_COEFF}}"  # W_2940_2017_2.snapcoeff (LAMMPS submodule)
    param_file: "{{SNAP_PARAM}}"  # W_2940_2017_2.snapparam (LAMMPS submodule)

integrator:
  style: velocity_verlet
  dt: 0.0005                # ps — Wood 2017 timestep.

neighbor:
  skin: 0.3                 # Å — T6 canonical skin.

thermo:
  every: 1                  # full-trace thermo for D-M8-13 byte-exact diff.

run:
  n_steps: 10

# M4 layer: opt-in deterministic TD scheduler (D-M4-11). K=1 ⇒ scheduler
# observes the legacy physics sequence — no time-dimension pipelining.
scheduler:
  td_mode: true
  pipeline_depth_cap: 1

# M5 layer: MPI host-staging comm backend. D-M5-9 Kahan-ring guarantees
# reduction-order determinism, required for the byte-exact gate.
comm:
  backend: mpi_host_staging
  topology: mesh

# M6 layer: GPU force path + GPU integrator via runtime::GpuContext.
# On Fp64ReferenceBuild this path MUST reproduce the CPU Reference thermo
# bit-for-bit (D-M6-7); with SNAP the reduction order is canonicalised by
# the reduce-then-scatter force accumulation (gpu/SPEC §6.1).
runtime:
  backend: gpu

# M7 layer: Pattern 2 two-level TD × SD scheduling. With 2 ranks and 2
# subdomains, each rank owns one subdomain; `linear_1d` splits the box along
# X so `P_space=2`. K=1 (`pipeline_depth_cap: 1`) keeps the scheduler in
# single-level mode, so the thermo stream is identical to a 1-rank run
# (D-M8-13 byte-exact gate; D-M7-10 analog for SNAP).
zoning:
  scheme: linear_1d
  subdomains: [2, 1, 1]
