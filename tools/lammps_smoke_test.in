# TDMD LAMMPS smoke test input.
# 500 atoms Al FCC (5x5x5), 100 steps NVE, EAM Zhou et al. 2001 (Al_zhou.eam.alloy).
# Invoked with `-var gpu on|off` to toggle GPU package.
#
# Success criteria:
#   - Trajectory completes without crash.
#   - Final total energy at step 100 is finite and reproducible.
#   - CPU and GPU runs agree within 1e-8 relative (double precision GPU build).

units           metal
atom_style      atomic
boundary        p p p

# GPU package must be declared BEFORE create_box. `-var gpu on|off` set by
# the driver script; `suffix gpu` routes eam/alloy → eam/alloy/gpu.
if "${gpu} == on" then &
  "package         gpu 1" &
  "suffix          gpu"

# Compact FCC aluminum: 5x5x5 unit cells = 500 atoms.
lattice         fcc 4.05
region          box block 0 5 0 5 0 5
create_box      1 box
create_atoms    1 box
mass            1 26.98

pair_style      eam/alloy
pair_coeff      * * Al_zhou.eam.alloy Al

velocity        all create 300.0 12345 loop geom

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

timestep        0.001    # 1 fs

fix             1 all nve

thermo          10
thermo_style    custom step temp pe etotal press

run             100
