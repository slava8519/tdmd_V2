# T4 LAMMPS scout script — Ni-Al EAM/alloy, 100 step.
# Variables (resolved via -var):
#   setup_data — absolute path to committed setup.data
#   eam_file   — absolute path to Mishin 2004 setfl
#   nsteps     — run length (default 100)

units           metal
atom_style      atomic
boundary        p p p

read_data       ${setup_data}

pair_style      eam/alloy
pair_coeff      * * ${eam_file} Ni Al

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

timestep        0.001

fix             1 all nve

thermo          10
thermo_style    custom step temp pe ke etotal press

run             ${nsteps}
