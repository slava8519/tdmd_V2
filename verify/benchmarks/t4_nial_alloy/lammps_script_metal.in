# T4 LAMMPS reference script — Ni-Al FCC Mishin-2004 EAM/alloy NVE, 864 atoms,
# 100 steps. Mirrors verify/benchmarks/t4_nial_alloy/config_metal.yaml bit-
# for-bit. Consumed by verify/t4/run_differential.py via the generic
# verify.harness.differential_runner (T2.8).
#
# Variables (resolved via `-var`):
#   workdir     — output directory; `final.data`, `lammps.log`, and
#                 `lammps.dump` are written here.
#   setup_data  — absolute path to the committed initial-state data file.
#   eam_file    — absolute path to the committed Mishin 2004 setfl file.
#
# Initial state comes from the committed ``setup.data`` (864 atoms, 432 Ni +
# 432 Al, seed 12345; see generate_setup.py for provenance). LAMMPS
# consumes that file verbatim — no `create_atoms`, no `velocity create` —
# so both engines see byte-identical lattice + velocity inputs.

units           metal
atom_style      atomic
boundary        p p p

read_data       ${setup_data}

pair_style      eam/alloy
pair_coeff      * * ${eam_file} Ni Al

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

timestep        0.001

fix             1 all nve

# High-precision thermo so comparator roundoff is dominated by physics, not by
# text-truncation. Identical to T1's configuration for comparability.
thermo          10
thermo_style    custom step temp pe ke etotal press
thermo_modify   format float "%.10e" norm no flush yes

# Route thermo to a dedicated log file to keep run_differential.py's parser
# simple — full stdout still goes to log.lammps.
log             ${workdir}/lammps.log

# Per-atom forces dump at the end of the run (required by the T2.8 forces-diff
# pathway). ``dump_modify sort id`` pins row order so LAMMPS's internal migration
# shuffles do not perturb the on-disk layout. ``format line "..."`` fixes the
# per-column precision to %.16e — well beyond the forces_relative = 1e-10
# threshold the harness checks.
dump            forces_d all custom 100 ${workdir}/lammps.dump id type x y z fx fy fz
dump_modify     forces_d sort id first no format line "%d %d %.16e %.16e %.16e %.16e %.16e %.16e"

run             100

# Final state, also nocoeff for symmetry.
write_data      ${workdir}/final.data nocoeff
