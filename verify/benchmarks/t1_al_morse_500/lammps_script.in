# T1 LAMMPS reference script — Al FCC Morse NVE, 500 atoms, 100 steps.
#
# Consumed by verify/t1/run_differential.py. Variables (resolved via `-var`):
#   workdir  — output directory; `setup.data`, `final.data`, and `thermo.log`
#              are written here.
#
# Matches verify/benchmarks/t1_al_morse_500/config.yaml bit-for-bit:
#   - Girifalco-Weizer Morse parameters
#   - hard-truncation cutoff at 6.0 Å (LAMMPS `pair_style morse` default
#     behaviour, matches TDMD `cutoff_strategy: hard_cutoff`)
#   - velocity-Verlet NVE, dt = 0.001 ps
#   - 100 steps, thermo every 10 steps

units           metal
atom_style      atomic
boundary        p p p

# Al FCC 5x5x5 unit cells = 500 atoms, box 20.25 x 20.25 x 20.25 Å.
lattice         fcc 4.05
region          simbox block 0 5 0 5 0 5
create_box      1 simbox
create_atoms    1 box
mass            1 26.9815385   # Al standard atomic mass

# Initial velocities at 300 K, seed 12345, deterministic with `loop geom`.
# Must happen before write_data so setup.data carries the initial v's.
velocity        all create 300.0 12345 loop geom dist gaussian

# Dump the initial state for TDMD to ingest (no pair coefficients yet, so
# setup.data contains only Masses, Atoms, Velocities — all supported by the
# TDMD lammps_data_reader).
write_data      ${workdir}/setup.data nocoeff

# Potential (matches TDMD config exactly).
pair_style      morse 6.0
pair_coeff      1 1 0.2703 1.1646 3.253

neighbor        0.3 bin
neigh_modify    every 1 delay 0 check yes

timestep        0.001

fix             1 all nve

# High-precision thermo so comparator roundoff is dominated by the physics,
# not by text-formatting truncation.
thermo          10
thermo_style    custom step temp pe ke etotal press
thermo_modify   format float "%.10e" norm no flush yes

# Route thermo to a dedicated log file; keeps run_differential.py parser
# simple (full stdout still goes to log.lammps).
log             ${workdir}/lammps.log

run             100

# Final state, also nocoeff for symmetry.
write_data      ${workdir}/final.data nocoeff
